                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/genre_history">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:padding="12dp"
                        android:text="@string/history"
                        android:fontFamily="@font/roboto"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                </FrameLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- HORROR -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/horrorCard"
                android:layout_width="150dp"
                android:layout_height="100dp"
                android:layout_margin="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="6dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/genre_horror">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:padding="12dp"
                        android:text="@string/horror"
                        android:fontFamily="@font/roboto"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                </FrameLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- MUSIC -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/musicCard"
                android:layout_width="150dp"
                android:layout_height="100dp"
                android:layout_margin="8dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/genre_music">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:padding="12dp"
                        android:text="@string/music"
                        android:fontFamily="@font/roboto"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                </FrameLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- MYSTERY -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/mysteryCard"
                android:layout_width="150dp"
                android:layout_height="100dp"
                android:layout_margin="8dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/genre_mystery">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:padding="12dp"
                        android:text="@string/mystery"
                        android:fontFamily="@font/roboto"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                </FrameLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ROMANCE -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/romanceCard"
                android:layout_width="150dp"
                android:layout_height="100dp"
                android:layout_margin="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="6dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/genre_romance">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:padding="12dp"
                        android:text="@string/romance"
                        android:fontFamily="@font/roboto"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                </FrameLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- SCI-FI -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/scifiCard"
                android:layout_width="150dp"
                android:layout_height="100dp"
                android:layout_margin="8dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/genre_sci">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:padding="12dp"
                        android:text="@string/sci_fi"
                        android:fontFamily="@font/roboto"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                </FrameLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- THRILLER -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/thrillerCard"
                android:layout_width="150dp"
                android:layout_height="100dp"
                android:layout_margin="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="6dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/genre_thriller">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:padding="12dp"
                        android:text="@string/thriller"
                        android:fontFamily="@font/roboto"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                </FrameLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- WAR -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/warCard"
                android:layout_width="150dp"
                android:layout_height="100dp"
                android:layout_margin="8dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/genre_war">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:padding="12dp"
                        android:text="@string/war"
                        android:fontFamily="@font/roboto"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                </FrameLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- WESTERN -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/westernCard"
                android:layout_width="150dp"
                android:layout_height="100dp"
                android:layout_margin="8dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/genre_western">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:padding="12dp"
                        android:text="@string/western"
                        android:fontFamily="@font/roboto"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                </FrameLayout>

            </com.google.android.material.card.MaterialCardView>

        </GridLayout>

        <!-- Next Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/nextButton"
            android:layout_width="327dp"
            android:layout_height="60dp"
            android:layout_marginTop="25dp"
            android:background="@drawable/black_3d_button"
            android:elevation="6dp"
            android:fontFamily="@font/roboto"
            android:stateListAnimator="@null"
            android:text="@string/next"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            app:backgroundTint="@null"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/genreGrid" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>