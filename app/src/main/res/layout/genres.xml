<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
        android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/background6"
        android:fitsSystemWindows="true"
        tools:context=".MainActivity">

        <!-- Movie Dates Logo -->
        <ImageView
            android:id="@+id/imageView"
            android:layout_width="327dp"
            android:layout_height="68dp"
            android:layout_marginTop="80dp"
            android:contentDescription="@string/moviedateslogo"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/logo_movie_dates" />

        <!-- "Help us determine what you like" Text-->
        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/roboto"
            android:gravity="center"
            android:lineSpacingExtra="2dp"
            android:paddingTop="10dp"
            android:text="@string/help_us_determine_what_you_like"
            android:textAlignment="center"
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/imageView" />

        <GridLayout
            android:id="@+id/genreGrid"
            android:layout_width="327dp"
            android:layout_height="0dp"
            android:layout_marginTop="24dp"
            android:columnCount="2"
            android:useDefaultMargins="true"
            app:layout_constraintTop_toBottomOf="@id/titleText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- ACTION -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/actionCard"
                android:layout_width="150dp"
                android:layout_height="100dp"
                android:layout_margin="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="6dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/genre_action">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:fontFamily="@font/roboto"
                        android:padding="12dp"
                        android:text="@string/action"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                </FrameLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ADVENTURE -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/adventureCard"
                android:layout_width="150dp"
                android:layout_height="100dp"
                android:layout_margin="8dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/genre_adventure">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:padding="12dp"
                        android:text="@string/adventure"
                        android:fontFamily="@font/roboto"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                </FrameLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ANIMATION -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/animationCard"
                android:layout_width="150dp"
                android:layout_height="100dp"
                android:layout_margin="8dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/genre_animation">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:padding="12dp"
                        android:text="@string/animation"
                        android:fontFamily="@font/roboto"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                </FrameLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- COMEDY -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/comedyCard"
                android:layout_width="150dp"
                android:layout_height="100dp"
                android:layout_margin="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="6dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/genre_comedy">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:padding="12dp"
                        android:text="@string/comedy"
                        android:fontFamily="@font/roboto"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                </FrameLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- CRIME -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/crimeCard"
                android:layout_width="150dp"
                android:layout_height="100dp"
                android:layout_margin="8dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/genre_crime">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:padding="12dp"
                        android:text="@string/crime"
                        android:fontFamily="@font/roboto"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                </FrameLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- DOCUMENTARY -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/documentaryCard"
                android:layout_width="150dp"
                android:layout_height="100dp"
                android:layout_margin="8dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/genre_documentary">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:padding="12dp"
                        android:text="@string/documentary"
                        android:fontFamily="@font/roboto"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                </FrameLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- DRAMA -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/dramaCard"
                android:layout_width="150dp"
                android:layout_height="100dp"
                android:layout_margin="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="6dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/genre_drama">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:padding="12dp"
                        android:text="@string/drama"
                        android:fontFamily="@font/roboto"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                </FrameLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- FAMILY -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/familyCard"
                android:layout_width="150dp"
                android:layout_height="100dp"
                android:layout_margin="8dp"
