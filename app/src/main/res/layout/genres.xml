<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/background6"
        android:fitsSystemWindows="true"
        tools:context=".MainActivity">

        <!-- Movie Dates Logo -->
        <ImageView
            android:id="@+id/imageView"
            android:layout_width="327dp"
            android:layout_height="68dp"
            android:layout_marginTop="80dp"
            android:contentDescription="@string/moviedateslogo"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/logo_movie_dates" />

        <!-- "Help us determine what you like" Text -->
        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/roboto"
            android:gravity="center"
            android:lineSpacingExtra="2dp"
            android:paddingTop="10dp"
            android:text="@string/help_us_determine_what_you_like"
            android:textAlignment="center"
            android:textColor="#000000"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/imageView" />

        <!-- Genres Grid -->
        <GridLayout
            android:id="@+id/genreGrid"
            android:layout_width="327dp"
            android:layout_height="0dp"
            android:layout_marginTop="24dp"
            android:columnCount="2"
            android:useDefaultMargins="true"
            app:layout_constraintTop_toBottomOf="@id/titleText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

        </GridLayout>

        <!-- Next Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/nextButton"
            android:layout_width="327dp"
            android:layout_height="60dp"
            android:layout_marginTop="25dp"
            android:background="@drawable/black_3d_button"
            android:elevation="6dp"
            android:fontFamily="@font/roboto"
            android:stateListAnimator="@null"
            android:text="@string/next"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            app:backgroundTint="@null"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/genreGrid" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>