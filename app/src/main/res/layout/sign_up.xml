<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:accessibilityHeading="false"
    android:background="@drawable/background2"
    android:fitsSystemWindows="true"
    android:visibility="visible"
    tools:context=".MainActivity"
    tools:visibility="visible"
    tools:ignore="UnusedAttribute">

    <!-- Movie Dates Logo -->
    <ImageView
        android:id="@+id/imageView"
        android:layout_width="327dp"
        android:layout_height="68dp"
        android:layout_marginTop="188dp"
        android:contentDescription="@string/moviedateslogo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/logo_movie_dates" />

    <!-- "Sign up to create an account" Text-->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:gravity="center"
        android:lineSpacingExtra="2dp"
        android:paddingTop="10dp"
        android:text="@string/sign_up_to_create_an_account"
        android:fontFamily="@font/roboto"
        android:textAlignment="center"
        android:textColor="#000000"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageView" />

    <!-- Email Input -->
    <EditText
        android:id="@+id/emailInput"
        android:layout_width="327dp"
        android:layout_height="40dp"
        android:layout_marginTop="10dp"
        android:autofillHints=""
        android:background="@drawable/input_background"
        android:hint="@string/email_domain_com"
        android:fontFamily="@font/roboto_r"
        android:inputType="textEmailAddress"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="#000000"
        android:textColorHint="#828282"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/titleText" />

    <!-- Password Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/passwordLayout"
        android:layout_width="327dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        app:endIconMode="password_toggle"
        app:hintEnabled="false"
        app:boxBackgroundMode="none"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/emailInput">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/passwordInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/input_background"
            android:gravity="center_vertical"
            android:hint="@string/password"
            android:fontFamily="@font/roboto_r"
            android:includeFontPadding="false"
            android:inputType="textPassword"
            android:paddingStart="16dp"
            android:paddingEnd="48dp"
            android:textColor="#000000"
            android:textColorHint="#828282"
            android:textSize="12sp" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Confirm Password Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/confirmLayout"
        android:layout_width="327dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        app:endIconMode="password_toggle"
        app:hintEnabled="false"
        app:boxBackgroundMode="none"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/passwordLayout">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/confirmInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/input_background"
            android:gravity="center_vertical"
            android:hint="@string/confirm_password"
            android:fontFamily="@font/roboto_r"
            android:includeFontPadding="false"
            android:inputType="textPassword"
            android:paddingStart="16dp"
            android:paddingEnd="48dp"
            android:textColor="#000000"
            android:textColorHint="#828282"
            android:textSize="12sp" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Sign Up Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/signUpButton"
        android:layout_width="327dp"
        android:layout_height="40dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/black_3d_button"
        android:elevation="6dp"
        android:fontFamily="@font/roboto"
        android:stateListAnimator="@null"
        android:text="@string/sign_up"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        app:backgroundTint="@null"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/confirmLayout" />

    <!-- Terms Layout-->
    <LinearLayout
        android:id="@+id/Terms"
        android:layout_width="327dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:layout_gravity="center_horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/signUpButton">

        <!-- "By clicking sign up, you agree to our" Text-->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/roboto_r"
            android:text="@string/by_clicking_sign_up_you_agree_to_our"
            android:textColor="#DADADA"
            android:textSize="12sp"
            android:textStyle="bold" />

        <!-- "Terms of Service" Text-->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/terms_of_service"
            android:fontFamily="@font/roboto"
            android:paddingStart="4dp"
            android:textColor="#000000"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Policy Layout-->
    <LinearLayout
        android:layout_width="327dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:layout_gravity="center_horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/Terms">

        <!-- "and" Text-->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/roboto"
            android:text="@string/and"
            android:textColor="#DADADA"
            android:textSize="12sp"
            android:textStyle="bold" />

        <!-- "Privacy Policy" Text-->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/privacy_policy"
            android:paddingStart="4dp"
            android:textColor="#000000"
            android:textSize="12sp"
            android:fontFamily="@font/roboto"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>