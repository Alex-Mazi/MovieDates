<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/dialog_bg"
    android:paddingStart="28dp"
    android:paddingEnd="28dp"
    android:paddingTop="32dp"
    android:paddingBottom="28dp"
    android:clipToPadding="false">

    <View
        android:id="@+id/dialogGlow"
        android:layout_width="180dp"
        android:layout_height="100dp"
        android:background="@drawable/dialog_glow"
        android:translationY="-30dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <FrameLayout
        android:id="@+id/dialogIconWrapper"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:background="@drawable/dialog_icon_bg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎬"
            android:textSize="28sp"
            android:gravity="center"
            android:layout_gravity="center"
            tools:ignore="HardcodedText" />

    </FrameLayout>

    <!-- "You're all set!" Text -->
    <TextView
        android:id="@+id/dialogTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/you_re_all_set"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:textStyle="bold"
        android:fontFamily="@font/roboto"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/dialogIconWrapper"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- "We've noted your taste..." Text -->
    <TextView
        android:id="@+id/dialogSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/we_ve_noted"
        android:textColor="#8A7FA8"
        android:textSize="14sp"
        android:fontFamily="@font/roboto"
        android:gravity="center"
        android:lineSpacingExtra="3dp"
        app:layout_constraintTop_toBottomOf="@id/dialogTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- "Let's go →" Text -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/dialogButton"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginTop="28dp"
        android:background="@drawable/dialog_button_bg"
        android:text="@string/let_s_go"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:fontFamily="@font/roboto"
        android:textAllCaps="false"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:minHeight="0dp"
        android:stateListAnimator="@null"
        app:backgroundTint="@null"
        app:cornerRadius="14dp"
        app:layout_constraintTop_toBottomOf="@id/dialogSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>